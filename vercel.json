{
    "version": 2,
    "buildCommand": "npm install --workspaces && npm run build",
    "outputDirectory": "client/dist",
  "functions": {
    "server/dist/index.js": {
            "memory": 1024,
            "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/v1/(.*)",
            "dest": "server/dist/index.js"
    },
    {
            "src": "/health",
            "dest": "server/dist/index.js"
    },
    {
      "src": "/(.*)",
            "dest": "client/dist/index.html"
    }
  ]
}
